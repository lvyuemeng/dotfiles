// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
	{
		"bindings": {},
	},
	{
		"context": "Editor",
		"bindings": {
			"space c f": "editor::Format",
		},
	},
	{
		"context": "Editor && mode == full",
		"bindings": {
			"alt-k": "editor::MoveLineUp",
			"alt-j": "editor::MoveLineDown",
			// "space a a": "assistant::InlineAssist"
		},
	},
	{
		"context": "Editor && mode==full && (vim_mode==normal || vim_mode==helix_normal)",
		"bindings": {
			"space c r": "editor::Rename",
			"space c a": "editor::ToggleCodeActions",
			"space f p": "workspace::CopyPath",
			// Buffer
			"shift-h": "pane::ActivatePreviousItem",
			"shift-l": "pane::ActivateNextItem",
			// resize
			"ctrl-left": ["vim::ResizePaneLeft", "50"],
			"ctrl-right": ["vim::ResizePaneRight", "50"],
			"ctrl-up": ["vim::ResizePaneUp", "50"],
			"ctrl-down": ["vim::ResizePaneDown", "50"],
		},
	},
	{
		"context": "Workspace",
		"bindings": {
			// Dock
			"alt-b": "workspace::ToggleLeftDock",
			"alt-B": "workspace::ToggleRightDock",
			// Symbol
			"space s s": "outline_panel::ToggleFocus",
			"space s p": "project_symbols::Toggle",
			// File
			"space f t": "terminal_panel::Toggle",
			// Section
			"space k f": "pane::DeploySearch",
			"space k e": "project_panel::ToggleFocus",
			"space k g": "git_panel::ToggleFocus",
			"space k p": "diagnostics::Deploy",
			"space k P": "diagnostics::DeployCurrentFile",
			"space k d": "debug_panel::ToggleFocus",
			"space k a": "agent::ToggleFocus",
		},
	},
	// disable
	{
		"context": "Workspace",
		"bindings": {
			"ctrl-shift-f": null,
		},
	},
	{
		// netrw compatibility
		"context": "ProjectPanel && not_editing",
		"bindings": {
			"ctrl-shift-c": "workspace::CopyPath",
			"a": "project_panel::NewFile",
			"A": "project_panel::NewDirectory",
			"r": "project_panel::Rename",
			"d": "project_panel::Trash",
			"D": "project_panel::Delete",
			"y": "project_panel::Copy",
			"x": "project_panel::Cut",
			"p": "project_panel::Paste",
			"O": "project_panel::RevealInFileManager",
		},
	},
	{
		"context": "GitPanel && ChangesList",
		"bindings": {
			"space c": "git_panel::FocusEditor",
		},
	},
	{
		"context": "GitPanel && CommitEditor",
		"bindings": {
			"space c": "git_panel::FocusChanges",
		},
	},
	{
		"context": "DebugPanel",
		"bindings": {
			"ctrl-`": "debug_panel::Toggle",
		},
	},
	{
		"context": "Terminal",
		"bindings": {
			"ctrl-`": "terminal_panel::ToggleFocus",
			"alt-`": "terminal::ToggleViMode",
		},
	},
	{
		"context": "Dock",
		"bindings": {
			"ctrl-w h": "workspace::ActivatePaneLeft",
			"ctrl-w l": "workspace::ActivatePaneRight",
			"ctrl-w k": "workspace::ActivatePaneUp",
			"ctrl-w j": "workspace::ActivatePaneDown",
		},
	},
	{
		"context": "Editor && vim_mode == insert",
		"bindings": {
			// "j k": "vim::NormalBefore"
		},
	},
]
